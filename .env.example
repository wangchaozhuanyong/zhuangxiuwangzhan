# Supabase Edge Function secrets:
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_ACCESS_TOKEN=
# Optional fallback only. Prefer configuring Telegram in the admin panel.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# LEAD_NOTIFICATION_WEBHOOK_URL=
# SITE_URL=https://flashcast.com.my
# MAINTENANCE_REMINDER_CRON_SECRET=
# Machine-to-machine secret for approved SEO/GEO content publishing through the protected content-publish Edge Function.
# CONTENT_PUBLISH_SECRET=
# TURNSTILE_SECRET_KEY=
# Optional. Used by the geocode-address Edge Function. If absent, the function falls back to OpenStreetMap lookup.
# GOOGLE_MAPS_API_KEY=
