      "\\bPVC\\b",
      "\\bMDF\\b",
      "\\bLED\\b",
      "\\bTV\\b",
      "\\b3D\\b",
      "\\bF&B\\b",
      "\\bHDB\\b",
      "\\bRM\\b",
      "\\b[a-zA-Z0-9._%+-]+@[a-zA-Z0-9.-]+\\.[A-Za-z]{2,}\\b",
      "https?://\\S+",
      "\\b\\+?60[\\d\\s-]+\\b",
      "\\b\\d+(?:\\.\\d+)?\\s*(?:mm|cm|m|sqft|AM|PM)\\b",
      "\\b\\d{4,}\\b"
