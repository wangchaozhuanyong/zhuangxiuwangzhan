  "resourcePurity": {
    "zhMinEnglishWords": 3,
    "zhMinEnglishChars": 18
  },
  "hardcoded": {
    "includeDirectories": [
      "src/pages",
      "src/components",
      "src/routes",
      "src/lib",
      "src/data"
    ],
    "includeFiles": [
      "index.html"
    ],
    "extensions": [
      ".ts",
      ".tsx",
      ".js",
      ".jsx",
      ".vue",
      ".html"
    ],
    "excludePathPatterns": [
      "(^|/)src/i18n/",
      "(^|/)src/components/ui/",
      "\\.(test|spec)\\.(ts|tsx|js|jsx)$",
      "(^|/)src/test/",
      "(^|/)src/lib/database\\.types\\.ts$",
      "(^|/)src/vite-env\\.d\\.ts$"
    ],
    "jsxAttributes": [
      "placeholder",
      "title",
      "alt",
      "aria-label",
      "aria-description",
      "aria-placeholder"
    ],
    "objectPropertyNames": [
      "title",
      "description",
      "label",
      "placeholder",
      "alt",
      "ariaLabel",
      "aria-label",
      "message",
      "text",
      "body",
      "error",
      "success",
      "empty",
      "help",
      "helpText",
      "confirmLabel",
      "cancelLabel",
      "header",
      "tooltip",
      "eyebrow",
      "subtitle",
      "content",
      "excerpt",
      "metaTitle",
      "metaDescription",
      "metaKeywords",
      "heroAlt",
      "buttonLabel",
      "button_label",
      "question",
      "answer",
      "name"
    ],
    "messageCallNames": [
      "toast",
      "alert",
      "confirm",
      "setStatus",
      "setError",
      "setMessage"
    ],
    "ignoredTextPatterns": [
      "^\\s*$",
      "^[\\d\\s.,:+#%()/-]+$",
      "^[-_a-z0-9]+$",
      "^#[A-Fa-f0-9]{3,8}$",
      "^https?://",
      "^mailto:",
      "^tel:",
      "^/",
      "^\\.",
      "^[A-Z_][A-Z0-9_]*$"
    ]
  },
  "runtime": {
    "baseUrl": "http://127.0.0.1:4197",
    "serverCommand": "npm run dev -- --host 127.0.0.1 --port 4197 --strictPort",
    "startupTimeoutMs": 45000,
    "navigationTimeoutMs": 30000,
    "routes": [
      { "locale": "zh-CN", "url": "/zh" },
      { "locale": "zh-CN", "url": "/zh/about" },
      { "locale": "zh-CN", "url": "/zh/services" },
      { "locale": "zh-CN", "url": "/zh/materials" },
      { "locale": "zh-CN", "url": "/zh/projects" },
      { "locale": "zh-CN", "url": "/zh/process" },
      { "locale": "zh-CN", "url": "/zh/faq" },
      { "locale": "zh-CN", "url": "/zh/quote" },
      { "locale": "zh-CN", "url": "/zh/contact" },
      { "locale": "en-US", "url": "/en" },
      { "locale": "en-US", "url": "/en/about" },
      { "locale": "en-US", "url": "/en/services" },
      { "locale": "en-US", "url": "/en/materials" },
      { "locale": "en-US", "url": "/en/projects" },
      { "locale": "en-US", "url": "/en/process" },
      { "locale": "en-US", "url": "/en/faq" },
      { "locale": "en-US", "url": "/en/quote" },
      { "locale": "en-US", "url": "/en/contact" }
    ],
    "scanAttributes": [
      "placeholder",
      "title",
      "alt",
      "aria-label",
      "aria-description",
      "aria-placeholder"
    ],
    "ignoredSelectors": [
      "script",
      "style",
      "noscript",
      "svg",
      "[aria-hidden=\"true\"]"
    ]
  }
