{
  "name": "flashcast-website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/validate-env.mjs --strict && node scripts/convert-images-to-webp.mjs && node scripts/prune-duplicate-images.mjs && node scripts/generate-sitemap.mjs && node scripts/generate-seo-manifest.mjs && node scripts/generate-llms.mjs",
    "build": "vite build",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "typecheck:strict-core": "tsc -p tsconfig.strict-core.json --noEmit",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:real-browsers": "node scripts/run-browserstack-compat.mjs",
    "test:installed-browsers": "node scripts/run-installed-browser-compat.mjs",
    "verify:preview": "node scripts/verify-preview.mjs",
    "verify:deploy-cache": "node scripts/verify-deploy-cache-consistency.mjs",
    "verify:seo-html": "node scripts/verify-seo-html.mjs",
    "verify:preview:server": "node scripts/verify-preview-with-server.mjs",
    "verify:admin-foundation": "node scripts/verify-admin-foundation.mjs",
    "verify:env": "node scripts/verify-env-separation.mjs",
    "backup:supabase": "node scripts/backup-supabase.mjs",
    "verify:backup": "node scripts/verify-backup-package.mjs",
    "deploy:retain-assets": "node scripts/retain-deploy-assets.mjs",
    "restore:backup:dry-run": "node scripts/restore-supabase-backup.mjs --dry-run",
    "generate:sitemap": "node scripts/generate-sitemap.mjs",
    "generate:llms": "node scripts/generate-llms.mjs",
    "images:webp": "node scripts/convert-images-to-webp.mjs",
    "images:prune": "node scripts/prune-duplicate-images.mjs",
    "videos:compress": "node scripts/compress-hero-videos.mjs",
    "seed:second-stage": "node scripts/upsert-second-stage-content.mjs",
    "seed:long-tail": "node scripts/upsert-long-tail-content.mjs",
    "content:humanize-blog": "node scripts/humanize-blog-posts.mjs",
    "content:humanize-blog:write": "node scripts/humanize-blog-posts.mjs --write",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toast": "^1.2.14",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@supabase/supabase-js": "^2.106.1",
    "@tanstack/react-query": "^5.83.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.462.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^6.30.3",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@types/node": "^22.16.5",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.28.0",
    "eslint": "^9.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^15.15.0",
    "jsdom": "^20.0.3",
    "postcss": "^8.5.6",
    "selenium-webdriver": "^4.44.0",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "wrangler": "^4.95.0"
  }
}
